# ============================================================================
# ENVIRONMENT MODE
# ============================================================================
# Set this to: local, dev, or prod
# local = Development on local machine
# dev = Development server
# prod = Production server
VITE_NODE_ENV=local
# ============================================================================
# LOCAL ENVIRONMENT URLs
# ============================================================================
VITE_API_LOCAL_URL=http://localhost:8001
# ============================================================================

# ============================================================================
# DEVELOPMENT ENVIRONMENT URLs
# ============================================================================
VITE_API_DEV_URL=https://devapi.stockwiz.in/api/v2/
# ============================================================================
# PRODUCTION ENVIRONMENT URLs
# ============================================================================
VITE_API_PROD_URL=https://api.stockwiz.in/api/v2/